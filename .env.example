# Copy to .env and adjust. All settings are optional; defaults are shown.

# --- Service ---
TRADEWATCH_HOST=0.0.0.0
TRADEWATCH_PORT=8000
TRADEWATCH_ALERT_BUFFER_SIZE=500
# Path to a custom detection ruleset (defaults to config/detection_rules.yaml)
# TRADEWATCH_RULES_PATH=config/detection_rules.yaml

# --- Trade source: "simulator" (default) or "kafka" ---
TRADEWATCH_SOURCE=simulator

# --- Built-in simulator (used when source == simulator) ---
TRADEWATCH_SIMULATOR_ENABLED=true
TRADEWATCH_SIMULATOR_SYMBOLS=AAPL,MSFT,BTC-USD,ETH-USD,TSLA
TRADEWATCH_SIMULATOR_TRADES_PER_SECOND=20
TRADEWATCH_SIMULATOR_ANOMALY_RATE=0.015
# TRADEWATCH_SIMULATOR_SEED=42

# --- Apache Kafka consumer (used when source == kafka; needs the [kafka] extra) ---
TRADEWATCH_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
TRADEWATCH_KAFKA_TOPIC=trades
TRADEWATCH_KAFKA_GROUP_ID=tradewatch
TRADEWATCH_KAFKA_AUTO_OFFSET_RESET=latest

# --- Security & observability ---
# If set, POST /trades requires header:  X-API-Key: <key>
# TRADEWATCH_API_KEY=change-me
TRADEWATCH_RATE_LIMIT_PER_MIN=600
# Comma-separated CORS allowlist ("" disables CORS)
TRADEWATCH_CORS_ORIGINS=
TRADEWATCH_GUARDRAILS_ENABLED=true
# Structured JSON logs + audit trail
TRADEWATCH_LOG_JSON=false
TRADEWATCH_LOG_LEVEL=INFO
# TRADEWATCH_AUDIT_LOG_PATH=logs/audit.jsonl
